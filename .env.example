# Bountylane Platform — Required Configuration
PRIVATE_KEY=0xYourPrivateKeyHere
CONTRACT_ADDRESS=0x0F9a91c54d286bA413E64a1277ccFcE935dEDEb1
PLATFORM_API_KEY=change-this-api-key
MAX_REWARD_MON=0.05
WRITE_RATE_LIMIT=30

# Optional: Requester testing key
REQUESTER_PRIVATE_KEY=0xYourRequesterPrivateKeyHere

# Optional: Groq API for Hybrid Agent LLM
GROQ_API_KEY=gsk_YourGroqApiKeyHere

# Agent Configuration (optional)
AGENT_ID=agent://hybrid-001
PLATFORM_URL=http://localhost:3001
SERVER_PORT=3002
LLM_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq
EXECUTION_STRATEGY=llm_guided
LOG_LEVEL=info

# Optional: Override Monad RPC (defaults to https://rpc.monad.xyz)
# MONAD_RPC_URL=https://rpc.monad.xyz

# Optional (UI): write endpoint auth header value
# VITE_PLATFORM_API_KEY=change-this-api-key
# VITE_API_URL=https://your-platform-api.example.com
# VITE_AGENT_URL=https://your-agent-api.example.com
# VITE_CONTRACT_ADDRESS=0xYourContractAddress

# Optional: Etherscan API for contract verification
# ETHERSCAN_API_KEY=YourEtherscanApiKey
